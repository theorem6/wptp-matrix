{
  "name": "@wptp/matrix",
  "version": "0.1.7",
  "description": "WPTP public compatibility matrix (source x target x verification grade)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theorem6/wptp-matrix.git"
  },
  "bin": {
    "wptp-compose": "./dist/compose-cli.js",
    "wptp-verify-harness": "./dist/verify-harness-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "compose": "tsx src/compose-cli.ts",
    "verify:harness": "tsx src/verify-harness-cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli-validate.ts",
    "site:validate": "node scripts/site-validate.mjs",
    "site:build": "node scripts/build-site.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compose": {
      "types": "./dist/compose.d.ts",
      "import": "./dist/compose.js"
    }
  },
  "dependencies": {
    "@wptp/ir": "github:theorem6/wptp-ir#v0.1.3",
    "@wptp/adapter-openapi": "github:theorem6/wptp-adapter-openapi#v0.1.1",
    "@wptp/adapter-browser": "github:theorem6/wptp-adapter-browser#v0.1.1",
    "@wptp/emit-nextjs": "github:theorem6/wptp-emit-nextjs#v0.1.1",
    "@wptp/emit-hono": "github:theorem6/wptp-emit-hono#v0.1.1",
    "@wptp/emit-fastify": "github:theorem6/wptp-emit-fastify#v0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "hono": "^4.6.0",
    "fastify": "^4.28.1",
    "tsx": "^4.22.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
